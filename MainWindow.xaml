    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="TurboDoc.MainWindow"
    Title="TurboDoc">
    <Grid Background="#0A0A0A">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TitleBar x:Name="TitleBar" Grid.Row="0" Title="TurboDoc" />
