{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["ESNext"],

        "module": "preserve",
        "moduleResolution": "bundler",
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,

        "skipLibCheck": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true
    }
}
