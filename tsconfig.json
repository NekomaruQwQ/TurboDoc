{
    "include": ["frontend"],
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["frontend/*"]
        },

        "lib": [
            "ESNext",
            "DOM",
            "DOM.Iterable"
        ],

        "jsx": "react-jsx",
        "jsxImportSource": "react",

        "module": "preserve",
        "moduleResolution": "bundler",
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,

        "skipLibCheck": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
    }
}
