{
    "compilerOptions": {
        "paths": {
            "@/*": ["./frontend/*"],
            "@server/*": ["./server/*"],
            "@shadcn/*": ["./frontend/3rdparty/shadcn/*"],
        },

        "target": "ESNext",
        "lib": ["ESNext", "DOM"],

        "module": "preserve",
        "moduleResolution": "bundler",
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,

        "skipLibCheck": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true
    }
}
