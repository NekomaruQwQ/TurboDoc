#### 5. `frontend/app.tsx` - Workspace loading and auto-save (⚠️ NEEDS IPC INTEGRATION)

**Current state:** App.tsx exists with basic structure but no IPC integration, using hardcoded test data.

**Required changes:**
- Add IPC initialization
- Load workspace from backend on mount
- Implement auto-save with debouncing
- Add loading state

```typescript
import { useEffect, useRef, useState } from 'react';
import { ResizableHandle, ResizablePanel, ResizablePanelGroup } from '@/components/ui/resizable';
import { Card } from '@/components/ui/card';
import { initIPC, loadWorkspace, saveWorkspace } from '@/ipc';
import { WorkspaceContext } from '@/global';
import { Explorer } from '@/explorer';
import type { Workspace } from '@/data';

export function App() {
  const [workspace, setWorkspace] = useState<Workspace | null>(null);
  const [isLoading, setIsLoading] = useState(true);
  const saveTimeoutRef = useRef<number | null>(null);

  // Initialize IPC and load workspace on mount
  useEffect(() => {
    initIPC();

    (async () => {
      try {
        setWorkspace(await loadWorkspace());
      } catch (err) {
        console.error(err);
        // Fallback to empty workspace on error
        setWorkspace({ groups: [] });
      }
      setIsLoading(false);
    })();
  }, []);

  // Auto-save workspace on changes (debounced by 1 second)
  useEffect(() => {
    if (!workspace || isLoading) return;

    if (saveTimeoutRef.current !== null) {
      clearTimeout(saveTimeoutRef.current);
    }

    saveTimeoutRef.current = setTimeout(() => {
      saveWorkspace(workspace)
        .catch(err => console.error('Auto-save failed:', err));
    }, 1000) as unknown as number;

    return () => {
      if (saveTimeoutRef.current !== null) {
        clearTimeout(saveTimeoutRef.current);
      }
    };
  }, [workspace, isLoading]);

  if (isLoading) {
    return <div>Loading...</div>;
  }

  return (
    <WorkspaceContext.Provider value={[workspace!, setWorkspace]}>
      <div className="flex-1">
        <div>header</div>
        <ResizablePanelGroup direction='horizontal'>
          <ResizablePanel defaultSize={1}>
            <Explorer />
          </ResizablePanel>
          <ResizableHandle className='mx-1 my-2'/>
          <ResizablePanel defaultSize={3} className='flex'>
            <Card className="flex-1 p-0.5 rounded-none rounded-tl-xl">
              <iframe id='iframe' src='https://docs.rs/' className="flex-1 rounded-tl-xl"/>
            </Card>
          </ResizablePanel>
        </ResizablePanelGroup>
      </div>
    </WorkspaceContext.Provider>
  );
}
```

**Key features:**
- Uses React hooks (not Preact)
- Async/await for IPC operations
- Auto-save with 1-second debounce
- Error handling with fallback to empty workspace
- shadcn/ui components (ResizablePanel, Card)

