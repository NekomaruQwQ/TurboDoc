{
    "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
    "html": {
        "experimentalFullSupportEnabled": true
    },
    "linter": {
        "rules": {
            "a11y": "off",
            "correctness": {
                "noUnusedFunctionParameters": "off"
            },
            "suspicious": {
                "noGlobalAssign": "off",
                "noAssignInExpressions": "off"
            }
        }
    },
    "formatter": {
        "enabled": false
    },
    "assist": {
        "enabled": false
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    }
}